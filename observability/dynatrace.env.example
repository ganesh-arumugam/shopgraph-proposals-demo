# Dynatrace OTLP ingest settings for the observability stack.
#
# Copy to `.env` in this (observability/) directory, or export these vars, then run:
#   docker compose -f docker-compose.yml -f docker-compose.dynatrace.yml up -d
# or, with the driver:
#   DT_OTLP_ENDPOINT=... DT_API_TOKEN=... ./demo.sh up
#
#   cp dynatrace.env.example .env   # (.env is gitignored)

# Dynatrace OTLP endpoint (no trailing /v1/traces — the exporter appends it).
#   SaaS:        https://<env-id>.live.dynatrace.com/api/v2/otlp
#   Managed:     https://<your-domain>/e/<env-id>/api/v2/otlp
#   ActiveGate:  https://<activegate-host>:9999/e/<env-id>/api/v2/otlp
DT_OTLP_ENDPOINT=https://<env-id>.live.dynatrace.com/api/v2/otlp

# API token with the "openTelemetryTrace.ingest" scope (Dynatrace > Access Tokens).
# Format: dt0c01.XXXXXXXX.YYYYYYYY
DT_API_TOKEN=dt0c01.REPLACE_ME