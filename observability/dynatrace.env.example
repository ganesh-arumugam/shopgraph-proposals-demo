# Dynatrace OTLP ingest settings for the observability stack.
#
# Put these in the repo-root .env (alongside APOLLO_KEY). The driver (demo.sh) loads
# the root .env automatically, so:
#   ./observability/demo.sh up      # Dynatrace export is on whenever DT_API_TOKEN is set

# Your Dynatrace SaaS environment id (the part before .live / .apps in the URL).
# demo.sh derives the endpoint:  https://<DT_ENVIRONMENT_ID>.live.dynatrace.com/api/v2/otlp
DT_ENVIRONMENT_ID=abc12345

# API access token with the "openTelemetryTrace.ingest" scope (Dynatrace > Access Tokens).
# Format: dt0c01.XXXXXXXX.YYYYYYYY  (this is the secret used as: Authorization: Api-Token <token>)
DT_API_TOKEN=dt0c01.REPLACE_ME

# Optional: set the full endpoint explicitly instead of DT_ENVIRONMENT_ID.
# Required for Managed / ActiveGate (the env-id derivation assumes SaaS .live):
#   Managed:    https://<your-domain>/e/<env-id>/api/v2/otlp
#   ActiveGate: https://<activegate-host>:9999/e/<env-id>/api/v2/otlp
# DT_OTLP_ENDPOINT=https://<env-id>.live.dynatrace.com/api/v2/otlp

# Note: OTLP to Dynatrace must be HTTP/protobuf (gRPC is not supported). Our collector
# uses the otlphttp exporter, so this is already handled.