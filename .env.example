# ─── Apollo GraphOS ───────────────────────────────────────────────────────────
# Personal API key — required for sync-reviewers (service keys can't list org members)
# Get from: https://studio.apollographql.com/user-settings/api-keys
APOLLO_KEY=user:gh.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxx

# Graph ID (not the ref). Visible in Studio → Graph Settings.
APOLLO_GRAPH_ID=your-graph-id

# Graph ref: <graph-id>@<variant>. Use a dev/staging variant, not main prod.
APOLLO_GRAPH_REF=your-graph-id@dev

# ─── Subgraph routing URLs ────────────────────────────────────────────────────
# Where subgraphs are reachable FROM the router (or from CI for rover publish).
# For local dev these point to localhost. For deployed demo, use public URLs.
PRODUCTS_SUBGRAPH_URL=http://localhost:4001/products/graphql
ORDERS_SUBGRAPH_URL=http://localhost:4001/orders/graphql
